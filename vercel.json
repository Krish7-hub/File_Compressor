{
  "version": 2,
  "builds": [
    { "src": "api/compress.py",   "use": "@vercel/python" },
    { "src": "api/decompress.py", "use": "@vercel/python" },
    { "src": "index.html",        "use": "@vercel/static" },
    { "src": "style.css",         "use": "@vercel/static" },
    { "src": "app.js",            "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/compress",   "dest": "/api/compress.py"   },
    { "src": "/api/decompress", "dest": "/api/decompress.py" },
    { "src": "/style.css",      "dest": "/style.css"         },
    { "src": "/app.js",         "dest": "/app.js"            },
    { "src": "/(.*)",           "dest": "/index.html"        }
  ]
}

{
  "version": 2,
  "builds": [
    { "src": "api/**/*.py", "use": "@vercel/python" },
    { "src": "index.html",  "use": "@vercel/static"  }
  ],
  "routes": [
    { "src": "/api/compress",   "dest": "/api/compress.py"   },
    { "src": "/api/decompress", "dest": "/api/decompress.py" },
    { "src": "/(.*)",           "dest": "/index.html"        }
  ]
}
